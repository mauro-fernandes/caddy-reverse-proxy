# global options
{
	admin off
	persist_config off
	auto_https off
	log {
		format json 
	}
	servers {
		trusted_proxies static private_ranges
	}
}

(lb_settings) {
	lb_policy round_robin
	lb_retries 100
	lb_try_duration 10s
	lb_try_interval 250ms
}

(passive_health_checks) {
	fail_duration 60s
	max_fails 300
	unhealthy_latency 5s
	unhealthy_request_count 200
}

# Bloco unificado na porta do Railway
:{$PORT} {
	log {
		format json
	}

	# --- LÓGICA DO BACKEND ---
	# Filtra requisições que chegam pelo domínio da API (ex: api.seusite.com)
	@backend host {$BACKEND_EXTERNAL_DOMAIN}
	handle @backend {
		reverse_proxy {
			dynamic a {
				name {$BACKEND_DOMAIN}
				port {$BACKEND_PORT}
				refresh 1s
				dial_timeout 30s
				versions ipv4 ipv6
			}
			import lb_settings
			import passive_health_checks
			header_up Host {upstream_hostport}
		}
	}

	# --- LÓGICA DO FRONTEND ---
	# Filtra requisições que chegam pelo domínio do App (ex: app.seusite.com)
	@frontend host {$FRONTEND_EXTERNAL_DOMAIN}
	handle @frontend {
		reverse_proxy {
			dynamic a {
				name {$FRONTEND_DOMAIN}
				port {$FRONTEND_PORT}
				refresh 1s
				dial_timeout 30s
				versions ipv4 ipv6
			}
			import lb_settings
			import passive_health_checks
			header_up Host {upstream_hostport}
		}
	}

	# Fallback para caso alguém acesse o IP direto ou outro domínio
	handle {
		abort
	}
}
